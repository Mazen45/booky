<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Saira:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Saira:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <title>New Note</title>
</head>

<body>
  <div class="container add-container">
    <div class="row justify-content-center">
      <div class="col-md-6 align-items-center">
        <div class="borderbtm mb-4">
          <h2>Add a new book</h2>
        </div>
        <%if(locals.error){%>
        <div class="alert alert-danger mb-3 mt-3 d-flex justify-content-center" role="alert">
          <%=error%>
        </div>
        <%}%>
        <form action="/<%=action%>" method="post">

        <input type="hidden" name="update" value="<%=book?book.id:''%>">
        <label for="name" class="mb-2 ">🕮 Book name</label>
        <div class="input-group mb-3">
          <input type="text" class="form-control secondary" name="title" placeholder="book name" value="<%=book&&book.title? book.title : ''%>" <%= action === "Update"? "readonly" : '' %> name="title" aria-label="book name" aria-describedby="basic-addon1">
        </div>
        <label for="isbn" class="mb-2">🕮 ISBN (optional)</label>
        <div class="input-group mb-3">
          <input type="text" class="form-control secondary" placeholder="isbn" name="isbn" value="<%=book&&book.isbn? book.isbn : '' %>" aria-label="book isbn" <%= action === "Update" ? "readonly" : ""%>>
        </div>
        <label for="description" class="mb-2">🕮 Book description</label>
        <div class="input-group mb-3">
          <textarea type="text" class="form-control normal secondary" placeholder="description" name="description" aria-label="description"><%=book&&book.description? book.description : '' %></textarea>
        </div>
        <label for="notes" class="mb-2">🕮 Your notes</label>
        <div class="input-group">
          <textarea class="form-control large secondary" name="notes" aria-label="With textarea" placeholder="Add your book notes here..."><%=book&&book.notes? book.notes : '' %></textarea>
        </div>

        <label for="rating" class="mt-3 mb-2">🕮 How strongly do you recommend this book out of 10?</label>
        <div class="input-group ">
          <input type="text" class="form-control secondary" placeholder="Rating" value="<%=book&&book.rating? book.rating : ''%>" name="rating" aria-label="Rating" aria-describedby="basic-addon1">
        </div>

        <div class="add-submit">
          <button type="submit" class=" btn btn-dark mt-4 borderbtm"><%= action %></button>
        </div>
        </form>
      </div>
    </div>
  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

</body>

</html>